// from the command palette.
[
  {
    "context": "Workspace",
    "bindings": {
      // "shift shift": "file_finder::Toggle"
    },
  },
  {
    "context": "Editor && vim_mode == insert",
    "bindings": {
      // "j k": "vim::NormalBefore"
    },
  },
  {
    "context": "Editor",
    "bindings": {
      "alt-shift-l": "editor::SelectLargerSyntaxNode"
    }
  },
  {
    "context": "Editor",
    "unbind": {
      "alt-shift-right": "editor::SelectLargerSyntaxNode"
    }
  },
  {
    "context": "Editor",
    "bindings": {
      "alt-shift-h": "editor::SelectSmallerSyntaxNode"
    }
  },
  {
    "context": "Editor",
    "unbind": {
      "alt-shift-left": "editor::SelectSmallerSyntaxNode"
    }
  },
  {
    "context": "Editor",
    "bindings": {
      "alt-right": "editor::MoveToNextSubwordEnd"
    }
  },
  {
    "context": "Editor",
    "unbind": {
      "ctrl-alt-right": "editor::MoveToNextSubwordEnd"
    }
  },
  {
    "context": "Editor",
    "bindings": {
      "alt-shift-right": "editor::SelectToNextSubwordEnd"
    }
  },
  {
    "context": "Editor",
    "unbind": {
      "ctrl-alt-shift-right": "editor::SelectToNextSubwordEnd"
    }
  },
  {
    "context": "Editor",
    "bindings": {
      "alt-left": "editor::MoveToPreviousSubwordStart"
    }
  },
  {
    "context": "Editor",
    "unbind": {
      "ctrl-alt-left": "editor::MoveToPreviousSubwordStart"
    }
  },
  {
    "context": "Editor",
    "bindings": {
      "alt-shift-left": "editor::SelectToPreviousSubwordStart"
    }
  },
  {
    "context": "Editor",
    "unbind": {
      "ctrl-alt-shift-left": "editor::SelectToPreviousSubwordStart"
    }
  },
  {
    "context": "Editor",
      "bindings": {
      "ctrl-b ctrl-m": "editor::ToggleBookmark"
    }
  },
  {
    "context": "Editor",
    "bindings": {
      "ctrl-b ctrl-n": "editor::GoToNextBookmark"
    }
  },
  {
    "context": "Editor",
    "bindings": {
      "ctrl-b ctrl-p": "editor::GoToPreviousBookmark"
    }
  },
  {
    "context": "Editor",
    "bindings": {
      "ctrl-b ctrl-v": "editor::ViewBookmarks"
    }
  },
  {
    "context": "Workspace",
    "bindings": {
      "ctrl-b ctrl-d": "workspace::ClearBookmarks"
    }
  },
  {
    "context": "ProjectPanel",
    "bindings": {
      "enter": "project_panel::OpenPermanent"
    }
  },
  {
    "context": "Editor",
    "bindings": {
      "ctrl-alt-shift-k": "editor::DuplicateLineUp"
    }
  },
  {
    "context": "Editor",
    "unbind": {
      "ctrl-alt-shift-up": "editor::DuplicateLineUp"
    }
  },
  {
    "context": "Editor",
    "bindings": {
      "ctrl-alt-shift-j": "editor::DuplicateLineDown"
    }
  },
  {
    "context": "Editor",
    "unbind": {
      "ctrl-alt-shift-down": "editor::DuplicateLineDown"
    }
  }
]
