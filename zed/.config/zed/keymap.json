// Zed keymap
//
// For information on binding keys, see the Zed
// documentation: https://zed.dev/docs/key-bindings
//
// To see the default key bindings run `zed: open default keymap`
// from the command palette.
[
  {
    "context": "Editor",
    "bindings": {
      "alt-right": "editor::MoveToNextSubwordEnd",
      "alt-shift-right": "editor::SelectToNextSubwordEnd",
      "alt-left": "editor::MoveToPreviousSubwordStart",
      "alt-shift-left": "editor::SelectToPreviousSubwordStart",

      "alt-u": "editor::MoveToStartOfParagraph",
      "alt-shift-u": "editor::SelectToStartOfParagraph",
      "alt-m": "editor::MoveToEndOfParagraph",
      "alt-shift-m": "editor::SelectToEndOfParagraph",

      "ctrl-shift-enter": "editor::NewlineAbove",
      "ctrl-enter": "editor::NewlineBelow",

      "ctrl-alt-shift-k": "editor::DuplicateLineUp",
      "ctrl-alt-shift-j": "editor::DuplicateLineDown",

      "alt-shift-l": "editor::SelectLargerSyntaxNode",
      "alt-shift-h": "editor::SelectSmallerSyntaxNode",

      "ctrl-b ctrl-m": "editor::ToggleBookmark",
      "ctrl-b ctrl-n": "editor::GoToNextBookmark",
      "ctrl-b ctrl-p": "editor::GoToPreviousBookmark",
      "ctrl-b ctrl-v": "editor::ViewBookmarks",
      "ctrl-b ctrl-d": "workspace::ClearBookmarks",
    },
  },
  {
    "context": "ProjectPanel",
    "bindings": {
      "enter": "project_panel::OpenPermanent",
    },
  },
]
